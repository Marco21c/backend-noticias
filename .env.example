# =====================
# ENTORNO ACTUAL
# =====================
NODE_ENV=development

# =====================
# CONFIGURACION DESARROLLO
# =====================
PORT_DEV=3000
APP_URL_DEV=http://localhost:3000
MONGODB_DEV=mongodb://localhost:27017/nombre_base_datos
CLIENT_DEV_URL=http://localhost:5173

# =====================
# CONFIGURACION PRODUCCION
# =====================
PORT_PROD=10000
APP_URL=https://tu-backend.onrender.com
MONGODB_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/nombre_db?retryWrites=true&w=majority
CLIENT_URL=https://tu-frontend.vercel.app

# =====================
# JWT
# =====================
JWT_SECRET=tu_jwt_secret_seguro_aqui
JWT_EXPIRES_IN=7d

# =====================
# SUPERADMIN INICIAL (opcional)
# =====================
INIT_SUPERADMIN=false
SUPERADMIN_NAME=Nombre
SUPERADMIN_LASTNAME=Apellido
SUPERADMIN_EMAIL=admin@ejemplo.com
SUPERADMIN_PASSWORD=ContraseñaSegura123!
